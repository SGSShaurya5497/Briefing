# ─── Next.js ──────────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-me-generate-with-openssl-rand-base64-32

# ─── Database (SQLite — PoC) ───────────────────────────────────────────────────
# Uses a local SQLite file. Zero setup — just run `npm run db:push`.
# Production upgrade: change to postgresql://user:pass@host:5432/dbname
# and update the `provider` line in prisma/schema.prisma to "postgresql".
DATABASE_URL="file:./dev.db"

# ─── Gemini API ───────────────────────────────────────────────────────────────
# Get your free API key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ─────────────────────────────────────────────────────────────────────────────
# FUTURE UPGRADES (uncomment when ready)
# ─────────────────────────────────────────────────────────────────────────────

# Google OAuth — swap CredentialsProvider in lib/auth.ts for GoogleProvider
# GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-client-secret

# Cloud Storage — replace lib/storage.ts implementation
# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-key
# CLOUDINARY_API_SECRET=your-secret

# Redis Rate Limiting — restore lib/rate-limit.ts imports in api/generate
# UPSTASH_REDIS_REST_URL=https://your-url.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-token
